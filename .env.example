# Copy this file to .env and fill in your real values.
# .env is for LOCAL testing only — never commit your real .env file.
# In GitHub Actions, these same values live as repository secrets instead.

DATABASE_URL=postgresql://xxxxx
DATA_PATH= data/online_retail_ii.xlsx
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxxxx
ANTHROPIC_API_KEY=
# 0 loads all available historical years on the first run. Use a positive
# value only to demonstrate a staged backfill (for example, 30 days per run).
CHUNK_DAYS=0
